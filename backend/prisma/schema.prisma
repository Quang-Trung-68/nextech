generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String               @id @default(cuid())
  name                   String
  email                  String               @unique
  password               String?
  role                   Role                 @default(USER)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  isActive               Boolean              @default(true)
  emailVerifyToken       String?              @unique
  emailVerifyTokenExpiry DateTime?
  isEmailVerified        Boolean              @default(false)
  avatar                 String?
  phone                  String?
  addresses              Address[]
  cart                   Cart?
  favorites              Favorite[]
  oauthAccounts          OAuthAccount[]
  orders                 Order[]
  passwordResetTokens    PasswordResetToken[]
  refreshTokens          RefreshToken[]
  reviews                Review[]
  revokedTokens          RevokedToken[]
  couponUsages           CouponUsage[]
  notifications          Notification[]
  posts                  Post[]
  stockImports           StockImport[]

  @@map("users")
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  fullName  String
  phone     String
  address   String
  city      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ward      String   @default("")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model RevokedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  revokedAt DateTime @default(now())
  reason    String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("revoked_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  logo        String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("brands")
}

model Product {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  description     String
  price           Decimal             @db.Decimal(15, 2)
  stock           Int
  category        String
  rating          Float               @default(0)
  numReviews      Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  brandId         String?
  brand           Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  isBestseller    Boolean             @default(false)
  isNewArrival    Boolean             @default(true)
  manufactureYear Int?
  salePrice       Decimal?            @db.Decimal(15, 2)
  saleExpiresAt   DateTime?
  saleStock       Int?
  saleSoldCount   Int                 @default(0)
  hasVariants       Boolean             @default(false)
  lowStockThreshold Int                 @default(5)
  /// Thông số hiển thị dạng bảng (không phải tùy chọn variant) — từ crawl JSON `specs`
  specsJson         Json?
  cartItems         CartItem[]
  favorites         Favorite[]
  orderItems        OrderItem[]
  images            ProductImage[]
  reviews           Review[]
  attributes        ProductAttribute[]
  variants          ProductVariant[]
  stockImports      StockImport[]
  serialUnits       SerialUnit[]

  @@index([brandId])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  publicId  String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductAttribute {
  id        String                  @id @default(cuid())
  productId String
  name      String
  position  Int                     @default(0)
  createdAt DateTime                @default(now())
  product   Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductAttributeValue[]

  @@index([productId])
  @@map("product_attributes")
}

model ProductAttributeValue {
  id          String                @id @default(cuid())
  attributeId String
  value       String
  position    Int                   @default(0)
  attribute   ProductAttribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variantValues ProductVariantValue[]

  @@index([attributeId])
  @@map("product_attribute_values")
}

model ProductVariant {
  id              String    @id @default(cuid())
  productId       String
  sku             String    @unique
  price           Decimal   @db.Decimal(15, 2)
  stock           Int       @default(0)
  imageUrl        String?
  salePrice       Decimal?  @db.Decimal(15, 2)
  saleExpiresAt   DateTime?
  saleStock       Int?
  saleSoldCount   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt         DateTime?
  lowStockThreshold Int       @default(5)

  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values       ProductVariantValue[]
  orderItems   OrderItem[]
  cartItems    CartItem[]
  stockImports StockImport[]
  serialUnits  SerialUnit[]

  @@index([productId])
  @@map("product_variants")
}

model ProductVariantValue {
  variantId        String
  attributeValueId String

  variant        ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([variantId, attributeValueId])
  @@map("product_variant_values")
}

model Order {
  id                    String        @id @default(cuid())
  userId                String
  status                OrderStatus   @default(PENDING)
  paymentStatus         PaymentStatus @default(UNPAID)
  paymentMethod         String
  totalAmount           Decimal       @db.Decimal(15, 2)
  discountAmount        Decimal       @default(0) @db.Decimal(15, 2)
  shippingAddress       Json
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  stripeClientSecret    String?
  stripePaymentIntentId String?       @unique
  couponId              Int?
  coupon                Coupon?       @relation(fields: [couponId], references: [id])
  couponUsage           CouponUsage?
  orderItems            OrderItem[]
  user                  User          @relation(fields: [userId], references: [id])
  invoice               Invoice?
  trackingCode          String?
  trackingUrl           String?
  carrierName           String?

  // VAT Invoice request (user điền tại checkout)
  vatInvoiceRequested    Boolean       @default(false)
  vatBuyerType           VatBuyerType? // null nếu vatInvoiceRequested = false
  vatBuyerName           String?       // Cá nhân: tên trên HĐ / Công ty: tên người đại diện
  vatBuyerAddress        String?       // Cá nhân: địa chỉ trên HĐ
  vatBuyerEmail          String?       // Công ty: email nhận hóa đơn
  vatBuyerCompany        String?       // Tên công ty
  vatBuyerTaxCode        String?       // Mã số thuế (10 hoặc 13 số)
  vatBuyerCompanyAddress String?       // Địa chỉ công ty (có thể khác shipping address)

  @@map("orders")
}

model OrderItem {
  id            String          @id @default(cuid())
  orderId       String
  productId     String
  variantId     String?
  quantity      Int
  price         Decimal         @db.Decimal(15, 2)
  originalPrice Decimal         @default(0) @db.Decimal(15, 2)
  order         Order           @relation(fields: [orderId], references: [id])
  product       Product         @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  review        Review?
  serialUnitId  String?         @unique
  assignedAt    DateTime?
  serialUnit    SerialUnit?     @relation(fields: [serialUnitId], references: [id])

  @@map("order_item")
}

model Review {
  id          String    @id @default(cuid())
  userId      String
  productId   String
  orderItemId String    @unique
  rating      Int
  comment     String?
  createdAt   DateTime  @default(now())
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id        String          @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId])
  @@map("cart_items")
}

model FailedEmail {
  id         Int       @id @default(autoincrement())
  type       String
  to         String
  data       Json
  attempts   Int       @default(0)
  lastError  String?
  status     String    @default("FAILED")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@map("failed_emails")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

model Coupon {
  id                Int              @id @default(autoincrement())
  code              String           @unique
  type              CouponDiscountType
  value             Float
  maxDiscountAmount Float?
  minOrderAmount    Float
  maxUsage          Int
  usedCount         Int              @default(0)
  expiresAt         DateTime
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  orders            Order[]
  couponUsages      CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id        Int      @id @default(autoincrement())
  couponId  Int
  userId    String
  orderId   String   @unique
  createdAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id])

  @@unique([couponId, userId])
  @@map("coupon_usages")
}

enum Role {
  USER
  ADMIN
}

enum VatBuyerType {
  INDIVIDUAL // Cá nhân
  COMPANY    // Doanh nghiệp
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKING
  SHIPPING
  COMPLETED
  CANCELLED
  RETURNED
}

enum SerialStatus {
  IN_STOCK
  RESERVED
  SOLD
  RETURNED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  orderId        String        @unique
  order          Order         @relation(fields: [orderId], references: [id])
  status         InvoiceStatus @default(DRAFT)

  // Snapshot người mua tại thời điểm đặt hàng
  buyerName      String
  buyerEmail     String
  buyerPhone     String?
  buyerAddress   String
  buyerCompany   String?
  buyerTaxCode   String?

  // Snapshot người bán tại thời điểm đặt hàng
  sellerName     String
  sellerAddress  String
  sellerTaxCode  String

  // Tài chính (VND — không có xu)
  subtotal       Decimal  @db.Decimal(12, 0)
  discountAmount Decimal  @default(0) @db.Decimal(12, 0)
  vatRate        Decimal  @default(0.10) @db.Decimal(4, 3)
  vatAmount      Decimal  @db.Decimal(12, 0)
  totalAmount    Decimal  @db.Decimal(12, 0)

  // Email
  emailSentAt    DateTime?

  issuedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  items          InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productName String
  sku         String?
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 0)
  totalPrice  Decimal @db.Decimal(12, 0)

  @@map("invoice_items")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}

/// Tần suất job đếm đơn so với ngưỡng (múi giờ Asia/Ho_Chi_Minh)
enum LowOrderAlertInterval {
  HOURLY
  DAILY
  MONTHLY
}

model ShopSettings {
  id          String   @id @default("singleton")
  shopName    String   @default("NexTech")
  shopAddress String   @default("")
  taxCode     String   @default("")
  bankAccount String?
  phone       String?
  email       String?
  vatRate     Decimal  @default(0.10) @db.Decimal(4, 3)
  /// Cảnh báo khi số đơn (theo kỳ theo dõi) thấp hơn ngưỡng — dùng cho job/thông báo admin
  lowOrderAlertEnabled  Boolean @default(false)
  lowOrderAlertThreshold Int     @default(5)
  lowOrderAlertInterval LowOrderAlertInterval @default(DAILY)
  /// Khóa kỳ đã gửi cảnh báo (tránh spam trùng kỳ)
  lowOrderAlertLastPeriodKey String?
  updatedAt   DateTime @updatedAt

  @@map("shop_settings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "order_status_changed" | "payment_result" | "new_order" | "low_stock"
  title     String
  message   String
  data      Json?    // { orderId, productId, productName, newStatus, ... }
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  posts     Post[]
  createdAt DateTime @default(now())

  @@map("categories")
}

model Tag {
  id    Int       @id @default(autoincrement())
  name  String    @unique
  slug  String    @unique
  posts PostTag[]

  @@map("tags")
}

model Post {
  id          Int        @id @default(autoincrement())
  title       String
  slug        String     @unique
  content     String     // HTML from rich text editor
  excerpt     String?    // Short summary, max 300 chars
  coverImage  String?    // Cloudinary URL
  status      PostStatus @default(DRAFT)
  readTime    Int?       // Estimated minutes
  publishedAt DateTime?
  scheduledAt DateTime? // When SCHEDULED — publish at this time (scheduler flips to PUBLISHED)
  viewCount   Int        @default(0)

  author     User      @relation(fields: [authorId], references: [id])
  authorId   String

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId Int?

  tags PostTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scheduledAt])
  @@map("posts")
}

model PostTag {
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId Int
  tag    Tag  @relation(fields: [tagId], references: [id])
  tagId  Int

  @@id([postId, tagId])
  @@map("post_tags")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

// ─── Inventory (serial / IMEI) ───────────────────────────────────────────────

model Supplier {
  id           String        @id @default(cuid())
  name         String
  phone        String?
  email        String?
  address      String?
  notes        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  stockImports StockImport[]

  @@map("suppliers")
}

model StockImport {
  id             String          @id @default(cuid())
  supplierId     String
  productId      String
  variantId      String?
  importedBy     String
  importDate     DateTime        @default(now())
  unitCost       Decimal?        @db.Decimal(15, 2)
  notes          String?
  totalUnits     Int
  supplier       Supplier        @relation(fields: [supplierId], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id])
  importedByUser User            @relation(fields: [importedBy], references: [id])
  serialUnits    SerialUnit[]
  createdAt      DateTime        @default(now())

  @@index([productId])
  @@index([supplierId])
  @@map("stock_imports")
}

model SerialUnit {
  id            String          @id @default(cuid())
  serial        String          @unique
  productId     String
  variantId     String?
  stockImportId String
  status        SerialStatus    @default(IN_STOCK)
  reservedAt    DateTime?
  soldAt        DateTime?
  returnedAt    DateTime?
  stockImport   StockImport     @relation(fields: [stockImportId], references: [id], onDelete: Cascade)
  product       Product         @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  orderItem     OrderItem?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, status])
  @@index([variantId, status])
  @@map("serial_units")
}
