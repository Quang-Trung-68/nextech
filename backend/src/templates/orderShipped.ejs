<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Đơn hàng đang giao! 🚚</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f6f8;font-family:Arial,Helvetica,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f6f8;padding:40px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
          <tr>
            <td style="background-color:#2563eb;padding:32px 40px;text-align:center;">
              <h1 style="margin:0;color:#ffffff;font-size:22px;font-weight:700;letter-spacing:0.5px;">
                <%= appName || 'NexTech' %>
              </h1>
            </td>
          </tr>
          <tr>
            <td style="padding:40px 40px 32px 40px;">
              <h2 style="margin:0 0 16px 0;color:#1e293b;font-size:20px;font-weight:600;">
                Đơn hàng của bạn đang trên đường vận chuyển! 🚚
              </h2>
              <p style="margin:0 0 12px 0;color:#475569;font-size:15px;line-height:1.6;">
                Xin chào <strong style="color:#1e293b;"><%= user.name %></strong>,
              </p>
              <p style="margin:0 0 24px 0;color:#475569;font-size:15px;line-height:1.6;">
                Đơn hàng của bạn đã được bàn giao cho đơn vị vận chuyển. Bạn có thể theo dõi hành trình đơn hàng bằng liên kết phía dưới.
              </p>

              <div style="background-color:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;padding:20px;margin-bottom:24px;">
                <p style="margin:0 0 8px 0;font-size:14px;color:#64748b;">
                  Mã đơn hàng: <strong style="color:#1e293b;">#<%= String(order.id).slice(-8).toUpperCase() %></strong>
                </p>
                <p style="margin:0;font-size:14px;color:#64748b;">
                  Trạng thái: 
                  <span style="display:inline-block;background-color:#3b82f6;color:#ffffff;padding:4px 8px;border-radius:4px;font-size:12px;font-weight:bold;">
                    SHIPPED
                  </span>
                </p>
              </div>

              <h3 style="margin:0 0 12px 0;font-size:16px;color:#1e293b;">Chi tiết sản phẩm</h3>
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:24px;border-collapse:collapse;">
                <%
                  function formatVNDEmail(amount) {
                    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(Number(amount));
                  }
                  function getDiscountPercentFromSnapshotEmail(price, originalPrice) {
                    const p = parseFloat(price);
                    const o = parseFloat(originalPrice);
                    if (!o || o <= 0 || p >= o) return 0;
                    return Math.round((1 - p / o) * 100);
                  }
                  function couponRuleDescE(c) {
                    if (!c) return '';
                    if (c.type === 'PERCENTAGE') {
                      var s = 'Giảm ' + Number(c.value) + '% trên tổng đơn';
                      if (c.maxDiscountAmount != null) s += ' (tối đa ' + Number(c.maxDiscountAmount).toLocaleString('vi-VN') + 'đ)';
                      return s;
                    }
                    return 'Giảm ' + Number(c.value).toLocaleString('vi-VN') + 'đ (cố định)';
                  }
                %>
                <% order.items.forEach(function(item) {
                  const discountPercent = getDiscountPercentFromSnapshotEmail(item.price, item.originalPrice);
                %>
                <tr>
                  <td style="padding:12px 0;border-bottom:1px solid #e2e8f0;font-size:14px;color:#475569;vertical-align:top;">
                    <%= item.name %> <strong style="color:#1e293b;">x<%= item.quantity %></strong>
                    <% if (item.variantSummary) { %>
                      <p style="margin:6px 0 0 0;color:#64748b;font-size:12px;line-height:1.4;">Loại: <%= item.variantSummary %></p>
                    <% } %>
                  </td>
                  <td align="right" style="padding:12px 0;border-bottom:1px solid #e2e8f0;font-size:14px;color:#1e293b;font-weight:bold;white-space:nowrap;vertical-align:top;">
                    <% if (discountPercent > 0) { %>
                      <span style="color:#e53e3e;font-weight:bold;display:block;">
                        <%= formatVNDEmail(item.price) %>
                      </span>
                      <span style="text-decoration:line-through;color:#999;font-size:12px;display:block;">
                        <%= item.originalPrice != null ? formatVNDEmail(item.originalPrice) : '' %>
                      </span>
                      <span style="color:#e53e3e;font-size:11px;"> (-<%= discountPercent %>%)</span>
                    <% } else { %>
                      <%= formatVNDEmail(item.price) %>
                    <% } %>
                  </td>
                </tr>
                <% }); %>
              </table>

              <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:24px;border-top:1px solid #e2e8f0;padding-top:16px;">
                <tr>
                  <td style="font-size:14px;color:#64748b;padding-bottom:8px;">Tạm tính:</td>
                  <td align="right" style="font-size:14px;color:#1e293b;padding-bottom:8px;font-weight:600;">
                    <%= formatVNDEmail(Number(order.totalAmount) + Number(order.discountAmount || 0)) %>
                  </td>
                </tr>
                <% if (order.discountAmount > 0) { %>
                <tr>
                  <td style="font-size:14px;color:#64748b;padding-bottom:8px;vertical-align:top;">
                    Mã giảm giá <%= order.coupon ? '(' + order.coupon.code + ')' : '' %>:
                    <% if (order.coupon) { %>
                      <span style="display:block;font-size:12px;color:#64748b;font-weight:normal;margin-top:4px;"><%= couponRuleDescE(order.coupon) %></span>
                    <% } %>
                  </td>
                  <td align="right" style="font-size:14px;color:#dc2626;padding-bottom:8px;font-weight:600;">
                    - <%= formatVNDEmail(order.discountAmount) %>
                  </td>
                </tr>
                <% } %>
                <tr>
                  <td style="font-size:16px;color:#1e293b;font-weight:bold;padding-top:8px;border-top:1px solid #f1f5f9;">Tổng thanh toán:</td>
                  <td align="right" style="font-size:20px;color:#2563eb;font-weight:bold;padding-top:8px;border-top:1px solid #f1f5f9;">
                    <%= Number(order.totalAmount).toLocaleString('vi-VN') %> ₫
                  </td>
                </tr>
              </table>

              <h3 style="margin:0 0 8px 0;font-size:16px;color:#1e293b;">Địa chỉ giao hàng</h3>
              <p style="margin:0 0 24px 0;font-size:14px;color:#475569;line-height:1.6;">
                <%= order.shippingAddress.fullName %><br/>
                <%= order.shippingAddress.phone %><br/>
                <%= order.shippingAddress.addressLine || order.shippingAddress.address %>, <%= order.shippingAddress.ward %>, <%= order.shippingAddress.city %>
              </p>

              <div style="text-align:center;margin-top:32px;">
                <% if (order.trackingUrl) { %>
                  <a href="<%= order.trackingUrl %>" style="display:inline-block;background-color:#2563eb;color:#ffffff;text-decoration:none;padding:12px 24px;border-radius:6px;font-weight:bold;font-size:14px;">
                    Theo dõi đơn hàng
                  </a>
                <% } else { %>
                  <p style="color:#64748b;font-size:14px;font-style:italic;background:#f1f5f9;padding:12px;border-radius:6px;">
                    Thông tin vận chuyển sẽ sớm được cập nhật
                  </p>
                <% } %>
              </div>
            </td>
          </tr>
          <tr>
            <td style="padding:24px 40px;border-top:1px solid #e2e8f0;text-align:center;">
              <p style="margin:0;color:#94a3b8;font-size:12px;line-height:1.5;">
                © <%= new Date().getFullYear() %> <%= appName || 'NexTech' %>. Mọi bản quyền được bảo lưu.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
