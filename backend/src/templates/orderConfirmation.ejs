<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Xác nhận đơn hàng #<%= order.id %></title>
</head>
<body style="margin:0;padding:0;background-color:#f4f6f8;font-family:Arial,Helvetica,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f6f8;padding:40px 0;">
    <tr>
      <td align="center">
        <table width="620" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:10px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.10);">

          <!-- Header -->
          <tr>
            <td style="background:linear-gradient(135deg,#1d4ed8 0%,#2563eb 100%);padding:36px 40px;text-align:center;">
              <h1 style="margin:0 0 4px 0;color:#ffffff;font-size:24px;font-weight:700;letter-spacing:0.5px;">
                <%= appName %>
              </h1>
              <p style="margin:0;color:#bfdbfe;font-size:13px;">Cảm ơn bạn đã mua sắm cùng chúng tôi!</p>
            </td>
          </tr>

          <!-- Success Badge -->
          <tr>
            <td style="padding:32px 40px 0 40px;text-align:center;">
              <div style="display:inline-block;background-color:#dcfce7;border-radius:50px;padding:10px 24px;">
                <span style="color:#16a34a;font-size:15px;font-weight:600;">✓ Đơn hàng đã được đặt thành công</span>
              </div>
              <h2 style="margin:20px 0 8px 0;color:#1e293b;font-size:20px;font-weight:700;">
                Xin chào <strong><%= order.user.name %></strong>!
              </h2>
              <p style="margin:0 0 8px 0;color:#475569;font-size:15px;line-height:1.6;">
                Đơn hàng của bạn đã được ghi nhận thành công. Chúng tôi sẽ xử lý và giao hàng sớm nhất có thể.
              </p>
            </td>
          </tr>

          <!-- Order Info Box -->
          <tr>
            <td style="padding:24px 40px 0 40px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;">
                <tr>
                  <td style="padding:20px 24px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td width="50%" style="padding-bottom:12px;vertical-align:top;">
                          <p style="margin:0 0 4px 0;color:#94a3b8;font-size:12px;text-transform:uppercase;letter-spacing:0.5px;">Mã đơn hàng</p>
                          <p style="margin:0;color:#1e293b;font-size:14px;font-weight:600;font-family:monospace;">#<%= order.id %></p>
                        </td>
                        <td width="50%" style="padding-bottom:12px;vertical-align:top;">
                          <p style="margin:0 0 4px 0;color:#94a3b8;font-size:12px;text-transform:uppercase;letter-spacing:0.5px;">Thời gian đặt hàng</p>
                          <p style="margin:0;color:#1e293b;font-size:14px;font-weight:600;">
                            <%= new Date(order.createdAt).toLocaleString('vi-VN', { dateStyle: 'medium', timeStyle: 'short' }) %>
                          </p>
                        </td>
                      </tr>
                      <tr>
                        <td width="50%" style="padding-bottom:12px;vertical-align:top;">
                          <p style="margin:0 0 4px 0;color:#94a3b8;font-size:12px;text-transform:uppercase;letter-spacing:0.5px;">Phương thức thanh toán</p>
                          <p style="margin:0;color:#1e293b;font-size:14px;font-weight:600;">
                            <%
                              const methodLabel = {
                                COD:    '💵 Thanh toán khi nhận hàng (COD)',
                                STRIPE: '💳 Thẻ tín dụng / Stripe',
                                VNPAY:  '🏦 VNPay',
                              };
                            %>
                            <%= methodLabel[order.paymentMethod] || order.paymentMethod %>
                          </p>
                        </td>
                        <td width="50%" style="padding-bottom:12px;vertical-align:top;">
                          <p style="margin:0 0 4px 0;color:#94a3b8;font-size:12px;text-transform:uppercase;letter-spacing:0.5px;">Trạng thái thanh toán</p>
                          <p style="margin:0;color:#1e293b;font-size:14px;font-weight:600;">
                            <% if (order.paymentStatus === 'PAID') { %>
                              <span style="color:#16a34a;">✅ Đã thanh toán</span>
                            <% } else if (order.paymentStatus === 'REFUNDED') { %>
                              <span style="color:#dc2626;">Đã hoàn tiền</span>
                            <% } else { %>
                              <span style="color:#d97706;">⏳ Chưa thanh toán</span>
                            <% } %>
                          </p>
                        </td>
                      </tr>
                      <tr>
                        <td colspan="2" style="vertical-align:top;">
                          <p style="margin:0 0 4px 0;color:#94a3b8;font-size:12px;text-transform:uppercase;letter-spacing:0.5px;">Trạng thái đơn hàng</p>
                          <%
                            const statusMap = {
                              PENDING:    { label: 'Chờ xử lý / Chờ thanh toán',  color: '#d97706', bg: '#fef3c7' },
                              PROCESSING: { label: 'Đang xử lý',      color: '#2563eb', bg: '#dbeafe' },
                              SHIPPED:    { label: 'Đang giao hàng',  color: '#7c3aed', bg: '#ede9fe' },
                              DELIVERED:  { label: 'Đã giao',         color: '#16a34a', bg: '#dcfce7' },
                              CANCELLED:  { label: 'Đã huỷ',          color: '#dc2626', bg: '#fee2e2' },
                            };
                            const s = statusMap[order.status] || { label: order.status, color: '#475569', bg: '#f1f5f9' };
                          %>
                          <span style="display:inline-block;background-color:<%= s.bg %>;color:<%= s.color %>;font-size:12px;font-weight:600;padding:3px 10px;border-radius:20px;">
                            <%= s.label %>
                          </span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Products Table -->
          <tr>
            <td style="padding:24px 40px 0 40px;">
              <h3 style="margin:0 0 12px 0;color:#1e293b;font-size:16px;font-weight:700;border-bottom:2px solid #e2e8f0;padding-bottom:10px;">
                🛍 Sản phẩm đã đặt
              </h3>
              <table width="100%" cellpadding="0" cellspacing="0">
                <!-- Table header -->
                <tr style="background-color:#f8fafc;">
                  <td style="padding:10px 12px;color:#64748b;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.3px;border-bottom:1px solid #e2e8f0;">Sản phẩm</td>
                  <td style="padding:10px 12px;color:#64748b;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.3px;border-bottom:1px solid #e2e8f0;text-align:center;">SL</td>
                  <td style="padding:10px 12px;color:#64748b;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.3px;border-bottom:1px solid #e2e8f0;text-align:right;">Đơn giá</td>
                  <td style="padding:10px 12px;color:#64748b;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.3px;border-bottom:1px solid #e2e8f0;text-align:right;">Thành tiền</td>
                </tr>

                <%
                  function formatVNDEmail(amount) {
                    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(Number(amount));
                  }
                  function getDiscountPercentFromSnapshotEmail(price, originalPrice) {
                    const p = parseFloat(price);
                    const o = parseFloat(originalPrice);
                    if (!o || o <= 0 || p >= o) return 0;
                    return Math.round((1 - p / o) * 100);
                  }
                  function couponRuleDescE(c) {
                    if (!c) return '';
                    if (c.type === 'PERCENTAGE') {
                      var s = 'Giảm ' + Number(c.value) + '% trên tổng đơn';
                      if (c.maxDiscountAmount != null) s += ' (tối đa ' + Number(c.maxDiscountAmount).toLocaleString('vi-VN') + 'đ)';
                      return s;
                    }
                    return 'Giảm ' + Number(c.value).toLocaleString('vi-VN') + 'đ (cố định)';
                  }
                %>

                <% order.orderItems.forEach(function(item, idx) {
                  const discountPercent = getDiscountPercentFromSnapshotEmail(item.price, item.originalPrice);
                %>
                <tr style="background-color:<%= idx % 2 === 0 ? '#ffffff' : '#f8fafc' %>;">
                  <td style="padding:12px 12px;color:#1e293b;font-size:14px;border-bottom:1px solid #f1f5f9;vertical-align:top;">
                    <%= item.product ? item.product.name : 'Sản phẩm không còn tồn tại' %>
                    <% if (item.variantSummary) { %>
                      <p style="margin:6px 0 0 0;color:#64748b;font-size:12px;line-height:1.4;">Loại: <%= item.variantSummary %></p>
                    <% } %>
                  </td>
                  <td style="padding:12px 12px;color:#475569;font-size:14px;border-bottom:1px solid #f1f5f9;text-align:center;">
                    <%= item.quantity %>
                  </td>
                  <td style="padding:12px 12px;border-bottom:1px solid #f1f5f9;text-align:right;white-space:nowrap;vertical-align:top;">
                    <% if (discountPercent > 0) { %>
                      <span style="color:#e53e3e;font-weight:bold;font-size:14px;display:block;">
                        <%= formatVNDEmail(item.price) %>
                      </span>
                      <span style="text-decoration:line-through;color:#999;font-size:12px;display:block;">
                        <%= formatVNDEmail(item.originalPrice) %>
                      </span>
                      <span style="color:#e53e3e;font-size:11px;">(-<%= discountPercent %>%)</span>
                    <% } else { %>
                      <span style="color:#475569;font-size:14px;">
                        <%= formatVNDEmail(item.price) %>
                      </span>
                    <% } %>
                  </td>
                  <td style="padding:12px 12px;color:#1e293b;font-size:14px;font-weight:600;border-bottom:1px solid #f1f5f9;text-align:right;white-space:nowrap;">
                    <%= formatVNDEmail(Number(item.price) * item.quantity) %>
                  </td>
                </tr>
                <% }) %>

                <!-- Summary rows -->
                <tr>
                  <td colspan="3" style="padding:16px 12px 0 12px;text-align:right;color:#64748b;font-size:14px;">
                    Tạm tính:
                  </td>
                  <td style="padding:16px 12px 0 12px;text-align:right;color:#1e293b;font-size:14px;font-weight:600;white-space:nowrap;">
                    <%= formatVNDEmail(Number(order.totalAmount) + Number(order.discountAmount || 0)) %>
                  </td>
                </tr>

                <% if (order.discountAmount > 0) { %>
                <tr>
                  <td colspan="3" style="padding:8px 12px 0 12px;text-align:right;color:#64748b;font-size:14px;vertical-align:top;">
                    Mã giảm giá <%= order.coupon ? '(' + order.coupon.code + ')' : '' %>:
                    <% if (order.coupon) { %>
                      <span style="display:block;font-size:12px;color:#64748b;font-weight:normal;margin-top:4px;"><%= couponRuleDescE(order.coupon) %></span>
                    <% } %>
                  </td>
                  <td style="padding:8px 12px 0 12px;text-align:right;color:#dc2626;font-size:14px;font-weight:600;white-space:nowrap;">
                    - <%= formatVNDEmail(order.discountAmount) %>
                  </td>
                </tr>
                <% } %>

                <tr>
                  <td colspan="3" style="padding:8px 12px 8px 12px;text-align:right;color:#1e293b;font-size:15px;font-weight:700;">
                    Phí vận chuyển:
                  </td>
                  <td style="padding:8px 12px 8px 12px;text-align:right;color:#16a34a;font-size:14px;font-weight:700;white-space:nowrap;">
                    Miễn phí
                  </td>
                </tr>

                <tr>
                  <td colspan="3" style="padding:16px 12px;text-align:right;color:#1e293b;font-size:16px;font-weight:700;border-top:2px solid #f1f5f9;">
                    Tổng thanh toán:
                  </td>
                  <td style="padding:16px 12px;text-align:right;color:#2563eb;font-size:20px;font-weight:900;white-space:nowrap;border-top:2px solid #f1f5f9;">
                    <%= formatVNDEmail(order.totalAmount) %>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Shipping Address -->
          <tr>
            <td style="padding:24px 40px 0 40px;">
              <h3 style="margin:0 0 12px 0;color:#1e293b;font-size:16px;font-weight:700;border-bottom:2px solid #e2e8f0;padding-bottom:10px;">
                📦 Địa chỉ giao hàng
              </h3>
              <div style="background-color:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:16px 20px;">
                <p style="margin:0 0 4px 0;color:#1e293b;font-size:14px;font-weight:600;">
                  <%= order.shippingAddress.fullName || order.user.name %>
                </p>
                <p style="margin:0 0 4px 0;color:#475569;font-size:14px;">
                  SĐT: <%= order.shippingAddress.phone || 'Chưa cung cấp' %> | Email: <%= order.user.email %>
                </p>
                <p style="margin:0;color:#475569;font-size:14px;line-height:1.5;">
                  📍 <% if (typeof order.shippingAddress === 'string') { %>
                    <%= order.shippingAddress %>
                  <% } else { %>
                    <%= [order.shippingAddress.addressLine || order.shippingAddress.address, order.shippingAddress.ward, order.shippingAddress.city].filter(Boolean).join(', ') %>
                  <% } %>
                </p>
              </div>
            </td>
          </tr>

          <!-- Notice -->
          <tr>
            <td style="padding:24px 40px 0 40px;">
              <div style="background-color:#eff6ff;border-left:4px solid #2563eb;border-radius:4px;padding:16px 20px;">
                <p style="margin:0 0 6px 0;color:#1e40af;font-size:13px;font-weight:600;">ℹ️ Thông tin quan trọng</p>
                <% if (order.paymentMethod === 'COD') { %>
                <p style="margin:0;color:#3b82f6;font-size:13px;line-height:1.6;">
                  Đơn hàng của bạn sẽ được giao trong 3–5 ngày làm việc. Vui lòng chuẩn bị sẵn
                  <strong><%= Number(order.totalAmount).toLocaleString('vi-VN') %>₫</strong> khi nhận hàng.
                </p>
                <% } else if (order.paymentMethod === 'STRIPE') { %>
                <p style="margin:0;color:#3b82f6;font-size:13px;line-height:1.6;">
                  Thanh toán của bạn đã được xử lý thành công qua Stripe. Đơn hàng sẽ được xử lý và giao trong 3–5 ngày làm việc.
                </p>
                <% } else { %>
                <p style="margin:0;color:#3b82f6;font-size:13px;line-height:1.6;">
                  Đơn hàng của bạn đang được xử lý. Chúng tôi sẽ thông báo khi đơn được giao cho đơn vị vận chuyển.
                </p>
                <% } %>
              </div>
            </td>
          </tr>

          <!-- CTA Button -->
          <tr>
            <td style="padding:28px 40px 20px 40px;text-align:center;">
              <table cellpadding="0" cellspacing="0" style="margin:0 auto;">
                <tr>
                  <td style="background-color:#2563eb;border-radius:7px;">
                    <a href="<%= appUrl || '#' %>/orders/<%= order.id %>"
                       style="display:inline-block;padding:14px 36px;color:#ffffff;font-size:15px;font-weight:600;text-decoration:none;border-radius:7px;letter-spacing:0.3px;">
                      Xem chi tiết đơn hàng →
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:32px 40px 28px 40px;border-top:1px solid #e2e8f0;margin-top:28px;text-align:center;">
              <p style="margin:0 0 6px 0;color:#94a3b8;font-size:12px;line-height:1.6;">
                Nếu bạn có thắc mắc, hãy liên hệ chúng tôi qua email hoặc hotline hỗ trợ.
              </p>
              <p style="margin:0;color:#cbd5e1;font-size:12px;">
                © <%= new Date().getFullYear() %> <strong><%= appName %></strong>. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
