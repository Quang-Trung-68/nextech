# =============================================================================
# NexTech - Environment Variables for Production Deployment
#
# Instructions:
# 1. Copy this file to .env in the PROJECT ROOT (next to docker-compose.yml)
# 2. Fill in ALL values marked with <your-...>
# 3. DO NOT commit .env to git (it's in .gitignore)
# =============================================================================

# --- PostgreSQL Database (used by the `postgres` service in docker-compose.prod.yml) ---
POSTGRES_DB=nextech_db
POSTGRES_USER=nextech_user
POSTGRES_PASSWORD=<your-strong-db-password>

# --- Backend ---
# docker-compose.prod.yml overrides DATABASE_URL for the backend container to use hostname `postgres`
DATABASE_URL=postgresql://nextech_user:<your-strong-db-password>@postgres:5432/nextech_db?schema=public
PORT=3000
NODE_ENV=production

# Frontend origin for CORS whitelist
CLIENT_URL=https://nextech.io.vn

# --- JWT & Cookie Secrets ---
ACCESS_TOKEN_SECRET=<your-long-random-secret-1>
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=<your-long-random-secret-2>
REFRESH_TOKEN_EXPIRES_IN=7d
COOKIE_SECRET=<your-long-random-secret-3>

# --- Stripe Payments ---
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>
STRIPE_CURRENCY=usd

# --- Cloudinary (Image Uploads) ---
CLOUDINARY_CLOUD_NAME=<your-cloudinary-cloud-name>
CLOUDINARY_API_KEY=<your-cloudinary-api-key>
CLOUDINARY_API_SECRET=<your-cloudinary-api-secret>

# --- Email (Nodemailer via Gmail App Password) ---
GMAIL_USER=<your-gmail-address>
GMAIL_APP_PASSWORD=<your-gmail-app-password>

# --- App Branding ---
APP_NAME=NexTech
FRONTEND_URL=https://nextech.io.vn

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_CALLBACK_URL=https://api.nextech.io.vn/api/auth/google/callback

# --- Facebook OAuth 2.0 ---
FACEBOOK_APP_ID=<your-facebook-app-id>
FACEBOOK_APP_SECRET=<your-facebook-app-secret>
FACEBOOK_CALLBACK_URL=https://api.nextech.io.vn/api/auth/facebook/callback

# --- Soketi (Websockets) ---
# These values MUST match the soketi.json config and your backend's Pusher client config
SOKETI_APP_ID=nextech-app
SOKETI_APP_KEY=nextech-key
SOKETI_APP_SECRET=nextech-secret
SOKETI_DEFAULT_APP_MAX_CONNS=100

# --- Vite Frontend Build Args ---
# Passed to the frontend Docker build at build time (baked into JS bundle)
VITE_API_URL=https://api.nextech.io.vn/api
VITE_STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>

# Soketi client config for the browser (must match backend SOKETI_APP_* values)
# wsHost: your API domain (Nginx proxies /app/* → soketi container)
# wsPort: 443 because we go through Nginx HTTPS
VITE_SOKETI_APP_KEY=nextech-key
VITE_SOKETI_HOST=api.nextech.io.vn
VITE_SOKETI_PORT=443
VITE_SOKETI_FORCE_TLS=true

# --- Certbot / Let's Encrypt ---
# Your email address for cert expiry notifications
CERTBOT_EMAIL=<your-email-for-letsencrypt>
