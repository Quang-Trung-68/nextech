VITE_API_URL="http://localhost:3000/api"
VITE_STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key_here"

# Soketi / Pusher — chỉ mở WebSocket khi bật (và đã chạy server Soketi port 6001)
# Trình duyệt luôn dùng localhost:6001 (hoặc host public khi deploy), KHÔNG dùng hostname Docker "soketi".
# Production Docker/CI: bắt buộc set VITE_SOKETI_ENABLED=true khi build (Dockerfile + secrets)
# VITE_SOKETI_ENABLED=true
# VITE_SOKETI_APP_KEY=nextech-key
# VITE_SOKETI_HOST=localhost
# VITE_SOKETI_PORT=6001
# VITE_SOKETI_FORCE_TLS=false
# Tắt hẳn realtime: VITE_SOKETI_DISABLED=true
#
# Docker Compose: các biến VITE_SOKETI_* có thể set trong docker-compose.yml (service frontend.environment).
